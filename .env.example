# Supabase (건강 DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# 네이버 블로그
NAVER_ID=your_naver_id
NAVER_PASSWORD=your_naver_password
NAVER_BLOG_ID=your_blog_id

# WordPress.com
WORDPRESS_SITE=yourblog.wordpress.com
WORDPRESS_USERNAME=your_username
WORDPRESS_APP_PASSWORD=your_application_password

# Google Blogger
# 1. console.cloud.google.com → 새 프로젝트 → Blogger API v3 활성화
# 2. 사용자 인증 정보 → OAuth 2.0 클라이언트 ID (데스크톱 앱) 생성
# 3. python tools/blogger_auth.py 실행해서 최초 인증
BLOGGER_BLOG_ID=your_blog_id
BLOGGER_CLIENT_ID=your_client_id.apps.googleusercontent.com
BLOGGER_CLIENT_SECRET=your_client_secret

# 슬랙 알림
# api.slack.com/apps → Incoming Webhooks → 웹훅 URL 복사
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
